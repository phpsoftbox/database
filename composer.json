{
    "name": "phpsoftbox/database",
    "description": "DBAL component for the PhpSoftBox framework",
    "type": "library",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2"
    },
    "autoload": {
        "psr-4": {
            "PhpSoftBox\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpSoftBox\\Database\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
