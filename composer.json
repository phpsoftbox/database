{
    "name": "phpsoftbox/database",
    "description": "DBAL component for the PhpSoftBox framework",
    "type": "library",
    "config": {
        "sort-packages": true
    },
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.93",
        "phpsoftbox/cli-app": "^0.1.0@beta",
        "phpsoftbox/cs-fixer": "^0.1.0@beta",
        "phpunit/phpunit": "^11.2"
    },
    "autoload": {
        "psr-4": {
            "PhpSoftBox\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpSoftBox\\Database\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs:fix": "vendor/bin/psb-cs-fixer fix",
        "cs:check": "vendor/bin/psb-cs-fixer check --diff"
    },
    "minimum-stability": "beta",
    "repositories": [
        { "type": "vcs", "url": "git@github.com:phpsoftbox/cs-fixer.git", "no-api": true },
        { "type": "vcs", "url": "git@github.com:phpsoftbox/cli-app.git", "no-api": true }
    ]
}
